{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug nt",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/bin/edit",
      "args": [
        "Inputfile/settingfile/setting_Trimesh_D_5.log"
      ],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "MIMode": "gdb",
      "miDebuggerPath": "gdb",
      "preLaunchTask": "build debug",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    }
  ]
}
