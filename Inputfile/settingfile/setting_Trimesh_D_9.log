#setting_D.log
Inputpath Inputfile/                # Path for input
Casepath case_input/2MW-5.8e19/                  # Path for SOLPS case
Outputpath Outputfile/test/data/    # Path for output
Databasepath Inputfile/database/ # Path for EIRENE database

N_poloidal          98      # number of the poloidal grid
N_radial            38      # number of the radial grid

K_log               0       # option: Particle way log
StepLog             0       # option: step log
K_H2_elastic        1       # option: molecule elastic collision
K_EcrossBDrift      0       # option: E cross B Drift
K_Recyc             1       # option: Plasma Recycling from Target
K_Rec               1       # option: Plasma Recombination from Target
K_Methane           0       # option: CD4 pump near Target
K_C                 0       # option: C pump near Target
K_Ar                0       # option: Ar pump near Target
K_database          1       # option: 1: ADAS, 2: EIRENE
K_database_Pra      2       # EIRENE H.10/H.8 energy-weighted rates
K_Maxwell           1       # EIRENE-aligned Maxwellian background/product velocity sampling
K_Ei                2       # legacy fallback; model 1 reconstructs EIRENE ELSTEP/FLSTEP + sheath
K_WallRefl          1       # option: 1: Trim database, 2: Fixed parameters
K_backScatter       1       # option: 1: Chance backing-scatter; 2: Real backing-scatter;
K_MarColl           1       # option: 1: 2 Separate sub-reactions; 2: 1 Sum-reaction;
K_flight            1       # option: 1: mean free path; 2: fixed time step;
K_CX_impurity       1       # option: stwich for impurity particle
K_Puff              0   0   0   0   0   # option
K_D2Flight          0       # match EIRENE NFOL=-1: local D2+ balance, no flight
K_abnormal_transport    1   # option
K_Rflect            2       # option: 1 for empirical formula of W. Eckstein; 2 for database of Trim; 3 for calculate from Trim
K_RflectDirection   3       # option: 1: Cosine distribution; 2: Half cosine distribution; 3: Specular reflection
backGridBoundry     1       # option
K_Prob              1       # option: 1: add the cross-section; 2: add the collision probability
K_H                 0       # option: H calculation
K_D                 1       $ option: D calculation
K_T                 0       # option: T calculation
K_back              2       # option: plasma backgroung. 1 for H, 2 for D, 3 for T
K_dn                1       # option: 1 for fixed 0.3; 2 file for reading from SOLPS
Ratio_T             0       # option: n_T / n_All
K_CX_DT             0       # option: cross-CX coll
K_DT                0       # option: 1 for D-T simulation
K_Wallelement       1       # option: 1 for W wall, 2 for C wall

dt                  1.e-8   # Time step
t_max               10      # Max time for Particle
numPar_flight       50000   # number of test flight from Grid
numPar_flight_D2    0   # number of pumping D2
numPar_flight_T2    0   # number of pumping T2
numPar_flight_CD4   0   # number of test flight of Methane
numPar_flight_Target 50000  # sum of test flight from Wall recycling
Num_D2_pump         0    # number of test flight of pumping D2 particle
Num_T2_pump         0    # number of test flight of pumping T2 particle
Num_CD4_pump        0    # sum of test flight for CD4 seeding
coeff_recyc_target  1       # recycling coefficient of target
coeff_ercyc_wall    1       # recycling coefficient of wall
coeff_puff          0.99    # recycling coefficient of puff location

K_Roulette          0       # baseline: variance reduction disabled
W_RouletteMin       0.05    # roulette trigger weight
W_RouletteTarget    0.2     # surviving particle weight
K_Splitting         0       # baseline: regional importance sampling disabled
W_SplitMax          2.0     # split trigger weight
W_SplitTarget       1.0     # desired child weight
W_SplitMin          0.05    # minimum child weight for regional splitting
MaxSplit            4       # maximum children per split event
MaxSplitDepth       1       # maximum split generations per source history
ImportanceOutside   1.0     # outside the valid B2 mesh
ImportanceDivertor  2.0     # divertor legs
ImportanceMainChamber 1.0   # non-divertor/main-chamber cells
ImportanceMainPoloidalBegin 25
ImportanceMainPoloidalEnd   72
K_H5Output          0       # option: write HDF5 output files
K_NNCs              1       # match EIRENE AMMONX neutral-neutral reactions
D2ElasticModel      3       # 0 off; 1 H.3 moment; 2 H.0/H.1/H.3; 3 EIRENE-like rejection sampling
MeshMode            3       # option: externmesh mode
K_DWTrimReflection  1       # option: 0 legacy D-W model; 1 selected D_on_W distribution model
K_DWTargetActualAngle 1     # use local B-to-target-normal incidence angle
DTargetIncidentModel 1      # 0 legacy mean; 1 EIRENE NEMODS=-3 normal monoenergetic; 2 drifting-flux sensitivity
DTargetSheathFactor  3.0    # sheath energy added along target normal in units of local Te
DTargetIncidentSamples 4096 # low-discrepancy samples per target for source-weight averaging
K_DTargetSourceMode 1       # 1 use recycled_neutral_flux_D; 2 use ni*abs(ua)*abs(b.normal)*target_area and TRIM split
DWTrimDatabase      D_on_W # match EIRENE input TRIM D_on_W database
SurfaceTemperature_eV 0.1   # EIRENE EWALL=-0.1: Maxwellian-flux wall temperature
DWTrimERMIN_eV      1.0     # EIRENE ERMIN: disable fast reflection below 1 eV
