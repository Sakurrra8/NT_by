#include <iostream>
#include <vector>
#include <cmath>
#include <fstream>
#include <iomanip>
#include <algorithm>

// ==========================================
// 1. 物理常数与单位转换
// ==========================================
const double Q_E = 1.60217663e-19; // 电子电荷 (J/eV)
const double M_P = 1.6726219e-27;  // 质子质量 (kg)
const double K_B = 1.380649e-23;   // 玻尔兹曼常数 (J/K)

// 例子：H + H+ -> H+ + H (AMJUEL H.3 3.1.8 反应)
// 质量设置 (单位: kg)
const double MASS_BEAM = 1.0 * M_P; // 中性 H
const double MASS_BG = 1.0 * M_P;   // 背景 H+
const double REDUCED_MASS = (MASS_BEAM * MASS_BG) / (MASS_BEAM + MASS_BG);

// ==========================================
// 2. AMJUEL H.3 截面拟合函数
// ==========================================
// 这里的系数仅为示例 (H.3 3.1.8 Charge Exchange)
// 实际使用时请替换为你数据库中的真实系数
// log(sigma) = sum( b_n * (log(E))^n )
// E in eV, Sigma in cm^2
std::vector<double> H3_COEFFS = {
    -3.271396786e+01, -5.905868868e-02, -1.269162445e-01,
    8.869541252e-03, -3.381229548e-03, 3.727268109e-04,
    1.205937235e-06, -6.227229917e-06, 4.265634902e-07};
// 拟合有效范围 (eV)
const double E_MIN_FIT = 0.1;
const double E_MAX_FIT = 1.0e5;

// 计算微观截面 sigma (cm^2)
// 输入 E_cm (质心系能量 eV)
double get_sigma_H3(double E_cm)
{
    // 边界保护
    if (E_cm < E_MIN_FIT)
        E_cm = E_MIN_FIT;
    if (E_cm > E_MAX_FIT)
        return 0.0; // 或者外推，视具体物理而定

    double ln_E = std::log(E_cm);
    double sum = 0.0;
    double p_ln_E = 1.0; // (ln E)^n

    for (double b : H3_COEFFS)
    {
        sum += b * p_ln_E;
        p_ln_E *= ln_E;
    }

    return std::exp(sum);
}

// ==========================================
// 3. 积分核心逻辑
// ==========================================
// 计算 Beam-Maxwellian 平均速率系数 <sigma v> (cm^3/s)
// E_beam_eV: 中性粒子能量 (eV)
// T_bg_eV:   背景离子温度 (eV)
double calc_effective_rate(double E_beam_eV, double T_bg_eV)
{

    // 将能量转换为速度 (m/s)
    double v_beam = std::sqrt(2.0 * E_beam_eV * Q_E / MASS_BEAM);

    // 背景热速度 v_th = sqrt(2kT/m)
    // 注意 T_bg_eV 需要转为焦耳
    double v_th = std::sqrt(2.0 * (T_bg_eV * Q_E) / MASS_BG);

    // 防止除零错误 (如果 T=0)
    if (v_th < 1.0)
        v_th = 1.0;
    if (v_beam < 1.0)
        v_beam = 1.0;

    // 积分范围设置
    // 高斯分布在 +/- 4*v_th 之外几乎为0
    // 积分变量是相对速度 v_r
    double v_lower = std::max(0.0, v_beam - 4.0 * v_th);
    double v_upper = v_beam + 4.0 * v_th;

    // 如果 v_beam 远小于 v_th，下限设为0
    if (v_beam < 4.0 * v_th)
        v_lower = 0.0;

    // 积分步数 (越多越准，通常100-200够了)
    const int STEPS = 200;
    double dv = (v_upper - v_lower) / STEPS;
    double integral = 0.0;

    for (int i = 0; i <= STEPS; ++i)
    {
        double v_r = v_lower + i * dv;
        if (v_r <= 0)
            continue; // 避免 log(0)

        // 1. 计算质心系碰撞能量 E = 0.5 * mu * v_r^2
        // 结果转回 eV
        double E_cm_J = 0.5 * REDUCED_MASS * v_r * v_r;
        double E_cm_eV = E_cm_J / Q_E;

        // 2. 查表/计算截面
        double sigma = get_sigma_H3(E_cm_eV); // cm^2

        // 3. 计算权重项
        // Term = [exp(-(v_r-v_b)^2/vth^2) - exp(-(v_r+v_b)^2/vth^2)]
        double arg1 = (v_r - v_beam) / v_th;
        double arg2 = (v_r + v_beam) / v_th;
        double weight = std::exp(-arg1 * arg1) - std::exp(-arg2 * arg2);

        double val = v_r * v_r * sigma * weight;

        // Simpson积分或者梯形积分，这里用梯形
        if (i == 0 || i == STEPS)
            integral += 0.5 * val;
        else
            integral += val;
    }

    integral *= dv;

    // 前置系数: 1 / (v_b * v_th * sqrt(pi))
    // 此时积分结果单位是: (m/s)^3 * cm^2
    // 我们需要最后的速率系数单位是 cm^3/s
    // 注意: v_r, v_b, v_th 都是 m/s。 sigma 是 cm^2。
    // 所以 integral 是 m^3/s * cm^2 / s... 维度有点乱
    // 让我们理一下：
    // Integral part ~ v^3 * sigma ~ (m/s)^3 * cm^2
    // Coeff part ~ 1/(v^2) ~ s^2/m^2
    // Result ~ (m/s) * cm^2 = 100 cm/s * cm^2 = 100 cm^3/s

    double coeff = 1.0 / (v_beam * v_th * std::sqrt(M_PI));
    double result_hybrid = coeff * integral; // 单位 m/s * cm^2

    // 转换为 cm^3/s (1 m/s = 100 cm/s)
    return result_hybrid * 100.0;
}

// ==========================================
// 4. 主程序：生成表格
// ==========================================
int main()
{
    // 定义网格
    // 建议使用对数网格
    int n_energy = 50;
    int n_temp = 50;

    double E_start = 0.1, E_end = 1.0e5; // eV
    double T_start = 0.1, T_end = 2.0e4; // eV

    std::vector<double> E_grid, T_grid;

    // 生成对数网格
    double log_E_step = std::log(E_end / E_start) / (n_energy - 1);
    double log_T_step = std::log(T_end / T_start) / (n_temp - 1);

    for (int i = 0; i < n_energy; ++i)
        E_grid.push_back(E_start * std::exp(i * log_E_step));
    for (int i = 0; i < n_temp; ++i)
        T_grid.push_back(T_start * std::exp(i * log_T_step));

    // 打开输出文件
    std::ofstream file("rate_table.csv");
    file << std::scientific << std::setprecision(4);

    // 写入表头
    file << "E_n(eV),T_i(eV),RateCoeff(cm3/s)\n";

    std::cout << "开始计算表格..." << std::endl;

    // 循环计算
    for (double E_n : E_grid)
    {
        for (double T_i : T_grid)
        {
            double rate = calc_effective_rate(E_n, T_i);

            // 写入CSV: 格式建议为 扁平化 (x, y, z) 或者是 矩阵形式
            // 这里演示扁平化格式，方便绘图
            file << E_n << "," << T_i << "," << rate << "\n";
        }
    }

    file.close();
    std::cout << "计算完成。结果已保存至 rate_table.csv" << std::endl;

    return 0;
}